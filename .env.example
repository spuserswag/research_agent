# --- OpenAI (Chat Completions API — gpt-4o by default) ---
OPENAI_API_KEY=

# --- Apollo.io (structured firmographic enrichment — OPTIONAL but recommended) ---
# Sign up at apollo.io, go to Settings → Integrations → API Keys.
# When set, the Researcher calls Apollo first (company enrich + people search) for
# headcount, funding, tech stack, and C-suite data before touching Perplexity.
# This cuts sonar-deep-research calls and reduces cost per run.
# If unset, the Researcher falls back to Perplexity for all firmographic data.
APOLLO_API_KEY=

# --- Perplexity (real-time discovery — news, interviews, job postings) ---
# Sign up at perplexity.ai/api. Uses sonar-pro (breadth) and sonar-deep-research (depth).
PERPLEXITY_API_KEY=

# --- Firecrawl (URL → clean markdown for deep extraction) ---
FIRECRAWL_API_KEY=

# --- Output location ---
# Where company profile folders are written. Defaults to ./profiles.
PROFILES_DIR=./profiles

# --- Email delivery (Resend) — OPTIONAL ---
# If unset, the orchestrator skips email and only writes the brief to disk.
# Sign up at resend.com (free up to 100 emails/day), verify a domain, create a key.
RESEND_API_KEY=
# Must be from a domain you've verified in Resend.
EMAIL_FROM=
# (Optional) Where AEs hitting Reply on the brief email get routed.
EMAIL_REPLY_TO=
