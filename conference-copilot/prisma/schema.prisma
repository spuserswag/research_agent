generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Conference {
  id          String      @id @default(cuid())
  name        String
  date        DateTime?
  location    String?
  address     String?
  exhibitors  Exhibitor[]
  contacts    Contact[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Exhibitor {
  id               String     @id @default(cuid())
  companyName      String
  boothNumber      String?
  industry         String?
  estimatedRevenue String?
  employeeCount    String?
  notes            String?
  isShortlisted    Boolean    @default(false)
  conferenceId     String
  conference       Conference @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model Contact {
  id           String     @id @default(cuid())
  name         String
  title        String?
  company      String?
  phoneNumber  String?
  emailAddress String?
  conferenceId String
  conference   Conference @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}
